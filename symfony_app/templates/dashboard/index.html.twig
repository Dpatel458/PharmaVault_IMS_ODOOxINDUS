{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
        </div>
        <button type="button" class="btn btn-sm btn-outline-secondary dropdown-toggle">
            <i class="bi bi-calendar"></i> This week
        </button>
    </div>
</div>

<!-- KPI Cards -->
<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-4">
    <div class="col">
        <div class="card bg-primary text-white h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-white-50">Total Products</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.totalProducts }}</h2>
                    </div>
                    <i class="bi bi-box-seam fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col">
        <div class="card bg-warning text-dark h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-dark-50">Low Stock Items</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.lowStockItems }}</h2>
                    </div>
                    <i class="bi bi-exclamation-triangle fs-1 text-dark-50"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col">
        <div class="card bg-danger text-white h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-white-50">Out of Stock</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.outOfStockItems }}</h2>
                    </div>
                    <i class="bi bi-x-octagon fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col">
        <div class="card bg-info text-dark h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-dark-50">Pending Receipts</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.pendingReceipts }}</h2>
                    </div>
                    <i class="bi bi-box-arrow-in-right fs-1 text-dark-50"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col">
        <div class="card bg-success text-white h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-white-50">Pending Deliveries</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.pendingDeliveries }}</h2>
                    </div>
                    <i class="bi bi-truck fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col">
        <div class="card bg-secondary text-white h-100 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="card-title text-uppercase text-white-50">Scheduled Transfers</h6>
                        <h2 class="mb-0 fw-bold">{{ metrics.scheduledTransfers }}</h2>
                    </div>
                    <i class="bi bi-arrow-left-right fs-1 text-white-50"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Filters & Recent Activity Module (Placeholder for AJAX) -->
<div class="card shadow-sm mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Recent Operations</h5>
        <div class="d-flex gap-2">
            <select class="form-select form-select-sm" id="filterType">
                <option value="">All Document Types</option>
                <option value="receipt">Receipts</option>
                <option value="delivery">Deliveries</option>
                <option value="transfer">Transfers</option>
                <option value="adjustment">Adjustments</option>
            </select>
            <select class="form-select form-select-sm" id="filterStatus">
                <option value="">All Statuses</option>
                <option value="draft">Draft</option>
                <option value="ready">Ready</option>
                <option value="done">Done</option>
            </select>
        </div>
    </div>
    <div class="card-body table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Ref</th>
                    <th>Type</th>
                    <th>Status</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody id="operationsTableBody">
                <tr>
                    <td colspan="5" class="text-center py-4 text-muted">Waiting for data...</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

{% endblock %}

{% block javascripts %}
<script>
    document.addEventListener('DOMContentLoaded', () => {
        // Here we will eventually add AJAX calls to fetch filtered data.
        console.log("Dashboard initialized. Waiting for real-time WebSocket connection...");
    });
</script>
{% endblock %}
