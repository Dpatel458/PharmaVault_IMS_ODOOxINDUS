{% extends 'base.html.twig' %}

{% block title %}Dashboard{% endblock %}

{% block body %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Dashboard</h1>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-4">
    
    <div class="col">
        <a href="{{ path('app_product_index') }}" class="text-decoration-none">
            <div class="card bg-primary text-white h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-white-50">Total Products</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.totalProducts }}</h2>
                        </div>
                        <i class="bi bi-box-seam fs-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>

    <div class="col">
        <a href="{{ path('app_warehouse_index') }}" class="text-decoration-none">
            <div class="card bg-dark text-white h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-white-50">Total Locations</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.totalWarehouses }}</h2>
                        </div>
                        <i class="bi bi-geo-alt fs-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col">
        <a href="{{ path('app_stock_index') }}" class="text-decoration-none">
            <div class="card bg-warning text-dark h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-dark-50">Low Stock</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.lowStockItems }}</h2>
                        </div>
                        <i class="bi bi-exclamation-triangle fs-1 text-dark-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col">
        <a href="{{ path('app_stock_index') }}" class="text-decoration-none">
            <div class="card bg-danger text-white h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-white-50">Out of Stock</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.outOfStockItems }}</h2>
                        </div>
                        <i class="bi bi-x-octagon fs-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col">
        <a href="{{ path('app_receipt_index') }}" class="text-decoration-none">
            <div class="card bg-info text-dark h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-dark-50">Pending Receipts</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.pendingReceipts }}</h2>
                        </div>
                        <i class="bi bi-box-arrow-in-right fs-1 text-dark-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col">
        <a href="{{ path('app_delivery_index') }}" class="text-decoration-none">
            <div class="card bg-success text-white h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-white-50">Pending Deliveries</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.pendingDeliveries }}</h2>
                        </div>
                        <i class="bi bi-truck fs-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
    
    <div class="col">
        <a href="{{ path('app_transfer_index') }}" class="text-decoration-none">
            <div class="card bg-secondary text-white h-100 shadow-sm dashboard-btn">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h6 class="card-title text-uppercase text-white-50">Scheduled Transfers</h6>
                            <h2 class="mb-0 fw-bold">{{ metrics.scheduledTransfers }}</h2>
                        </div>
                        <i class="bi bi-arrow-left-right fs-1 text-white-50"></i>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<div class="card shadow-sm mb-4">
    <div class="card-header bg-light">
        <h5 class="mb-0">Quick Guide</h5>
    </div>
    <div class="card-body text-center py-4">
        <p class="text-muted">Click any box above to manage products, stock, and inventory operations.</p>
    </div>
</div>
{% endblock %}

{% block stylesheets %}
<style>
    .dashboard-btn {
        transition: all 0.3s ease;
        border: none;
        position: relative;
        overflow: hidden;
    }
    
    .dashboard-btn:hover {
        transform: translateY(-8px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.15) !important;
        cursor: pointer;
    }

    .dashboard-btn:active {
        transform: translateY(-2px);
    }

    .dashboard-btn:hover .card-body {
        filter: brightness(1.05);
    }
</style>
{% endblock %}