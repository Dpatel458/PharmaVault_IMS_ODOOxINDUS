{% extends 'base.html.twig' %}

{% block body %}
<div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2">Locations (Cities)</h1>
    <a href="{{ path('app_location_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg"></i> Create new
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body p-0">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th style="width: 100px;">Id</th>
                    <th style="width: 150px;">Short Code</th>
                    <th>Name</th>
                    {# "Warehouse" nu column ahiya thi kadhi nakhyu che #}
                </tr>
            </thead>
            <tbody>
            {% for loc in locations %}
                <tr>
                    <td>{{ loc.id }}</td>
                    <td><span class="badge bg-info text-dark">{{ loc.shortCode }}</span></td>
                    <td class="fw-bold">{{ loc.name }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="3" class="text-center py-4 text-muted">
                        No cities found. Click "Create new" to add a location.
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}