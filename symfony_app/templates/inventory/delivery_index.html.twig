{% extends 'base.html.twig' %}

{% block title %}Outgoing Deliveries{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Outgoing Deliveries</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newDeliveryModal">
            Create Delivery Order
        </button>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Order #</th>
                <th>Date</th>
                <th>Customer Name</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for delivery in deliveries %}
            <tr>
                <td>{{ delivery.id }}</td>
                <td>{{ delivery.createdAt|date('Y-m-d H:i') }}</td>
                <td>{{ delivery.customer }}</td>
                <td>
                    {% if delivery.status == 'draft' %}
                        <span class="badge bg-secondary">Draft</span>
                    {% else %}
                        <span class="badge bg-success">Done</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_delivery_show', {'id': delivery.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center py-3">No deliveries found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <!-- New Delivery Modal -->
    <div class="modal fade" id="newDeliveryModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('app_delivery_new') }}" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">New Delivery Order</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="customer" class="form-label">Customer Name</label>
                            <input type="text" class="form-control" id="customer" name="customer" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Draft</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
