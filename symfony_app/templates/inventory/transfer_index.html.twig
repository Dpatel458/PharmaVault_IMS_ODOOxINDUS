{% extends 'base.html.twig' %}

{% block title %}Internal Transfers{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Internal Transfers</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newTransferModal">
            Create Transfer
        </button>
    </div>

    {% for message in app.flashes('danger') %}
        <div class="alert alert-danger">{{ message }}</div>
    {% endfor %}

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>TR #</th>
                <th>Date</th>
                <th>Source</th>
                <th>Destination</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for transfer in transfers %}
            <tr>
                <td>{{ transfer.id }}</td>
                <td>{{ transfer.createdAt|date('Y-m-d H:i') }}</td>
                <td>{{ transfer.sourceLocation.name }}</td>
                <td>{{ transfer.destinationLocation.name }}</td>
                <td>
                    {% if transfer.status == 'draft' %}
                        <span class="badge bg-secondary">Draft</span>
                    {% else %}
                        <span class="badge bg-success">Done</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_transfer_show', {'id': transfer.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center py-3">No transfers found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <!-- New Transfer Modal -->
    <div class="modal fade" id="newTransferModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('app_transfer_new') }}" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">New Internal Transfer</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="source_id" class="form-label">Source Warehouse</label>
                            <select class="form-select" id="source_id" name="source_id" required>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="dest_id" class="form-label">Destination Warehouse</label>
                            <select class="form-select" id="dest_id" name="dest_id" required>
                                {% for w in warehouses %}
                                    <option value="{{ w.id }}">{{ w.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Draft</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
