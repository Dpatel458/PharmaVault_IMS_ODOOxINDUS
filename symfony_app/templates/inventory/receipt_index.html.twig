{% extends 'base.html.twig' %}

{% block title %}Incoming Receipts{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Incoming Receipts</h1>
        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#newReceiptModal">
            Create New Receipt
        </button>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Receipt #</th>
                <th>Date</th>
                <th>Supplier</th>
                <th>Status</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for receipt in receipts %}
            <tr>
                <td>{{ receipt.id }}</td>
                <td>{{ receipt.createdAt|date('Y-m-d H:i') }}</td>
                <td>{{ receipt.supplier }}</td>
                <td>
                    {% if receipt.status == 'draft' %}
                        <span class="badge bg-secondary">Draft</span>
                    {% else %}
                        <span class="badge bg-success">Done</span>
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('app_receipt_show', {'id': receipt.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center py-3">No receipts found.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <!-- New Receipt Modal -->
    <div class="modal fade" id="newReceiptModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form action="{{ path('app_receipt_new') }}" method="POST">
                    <div class="modal-header">
                        <h5 class="modal-title">New Receipt</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label for="supplier" class="form-label">Supplier Name</label>
                            <input type="text" class="form-control" id="supplier" name="supplier" required>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-primary">Create Draft</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}
