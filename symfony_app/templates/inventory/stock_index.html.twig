{% extends 'base.html.twig' %}

{% block title %}Current Stock{% endblock %}

{% block body %}
    <div class="pt-3 pb-2 mb-3 border-bottom d-flex justify-content-between">
        <h1 class="h2">Current Stock Levels</h1>
        <a href="{{ path('app_adjustment_index') }}" class="btn btn-primary">Make Adjustment</a>
    </div>

    <table class="table table-hover align-middle shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>Warehouse</th>
                <th>Product</th>
                <th>SKU</th>
                <th>Quantity</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
        {% for stock in stocks %}
            {# Logic for Red and Yellow rows #}
            {% set rowClass = '' %}
            {% set statusText = 'In Stock' %}
            {% set badgeClass = 'bg-success' %}

            {% if stock.quantity == 0 %}
                {% set rowClass = 'table-warning' %} {# Out of Stock: Yellow #}
                {% set statusText = 'Out of Stock' %}
                {% set badgeClass = 'bg-dark' %}
            {% elseif stock.quantity < 10 %}
                {% set rowClass = 'table-danger' %}  {# Low Stock (<10): Red #}
                {% set statusText = 'Low Stock' %}
                {% set badgeClass = 'bg-danger' %}
            {% endif %}

            <tr class="{{ rowClass }}">
                <td>{{ stock.warehouse.name }}</td>
                <td>{{ stock.product.name }}</td>
                <td><span class="badge bg-secondary">{{ stock.product.sku }}</span></td>
                <td>
                    <strong>{{ stock.quantity }}</strong> {{ stock.product.unit }}
                </td>
                <td>
                    <span class="badge {{ badgeClass }}">{{ statusText }}</span>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" class="text-center py-3">No stock records found. Receive stock first!</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}

{% block stylesheets %}
<style>
    /* Table rows par thodi dark effect jethi text barabar dekhay */
    .table-danger {
        --bs-table-bg: #f8d7da; /* Light Red background */
        color: #842029;
    }
    .table-warning {
        --bs-table-bg: #fff3cd; /* Light Yellow background */
        color: #664d03;
    }
</style>
{% endblock %}