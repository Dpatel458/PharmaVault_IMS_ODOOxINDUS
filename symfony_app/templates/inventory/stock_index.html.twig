{% extends 'base.html.twig' %}

{% block title %}Current Stock{% endblock %}

{% block body %}
    <div class="pt-3 pb-2 mb-3 border-bottom d-flex justify-content-between">
        <h1 class="h2">Current Stock Levels</h1>
        <a href="{{ path('app_adjustment_index') }}" class="btn btn-primary">Make Adjustment</a>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Warehouse</th>
                <th>Product</th>
                <th>SKU</th>
                <th>Quantity</th>
            </tr>
        </thead>
        <tbody>
        {% for stock in stocks %}
            <tr>
                <td>{{ stock.warehouse.name }}</td>
                <td>{{ stock.product.name }}</td>
                <td><span class="badge bg-secondary">{{ stock.product.sku }}</span></td>
                <td><strong>{{ stock.quantity }}</strong> {{ stock.product.unit }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4" class="text-center py-3">No stock records found. Receive stock first!</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
