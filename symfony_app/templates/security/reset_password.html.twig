{% extends 'base.html.twig' %}

{% block title %}Set New Password{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="text-center mb-4">
            <i class="bi bi-shield-lock display-3 text-warning"></i>
            <h1 class="h3 mt-3 mb-1 font-weight-normal">Create New Password</h1>
            <p class="text-muted">Enter a strong new password</p>
        </div>

        <div class="card shadow border-0 p-4" style="border-radius: 1rem;">
            <div class="card-body">
                <form method="post">
                    <div class="mb-4">
                        <label for="password" class="form-label fw-bold">New Password</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" id="password" class="form-control border-start-0 ps-0" placeholder="••••••••" required autofocus minlength="6">
                        </div>
                        <div class="form-text text-muted small mt-1">Make sure it's at least 6 characters.</div>
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-lg btn-warning bg-gradient py-2 rounded-pill shadow-sm">
                            <i class="bi bi-check-circle me-2"></i> Reset Password
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
