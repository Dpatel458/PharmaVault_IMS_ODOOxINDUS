{% extends 'base.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-header bg-warning text-dark text-center">
                    <h4>Reset Password</h4>
                </div>
                <div class="card-body">
                    {% for message in app.flashes('danger') %}
                        <div class="alert alert-danger">{{ message }}</div>
                    {% endfor %}
                    
                    <p>Enter your email address and we will send you a 6-digit OTP code to reset your password.</p>
                    
                    <form method="post">
                        <label for="email">Email address</label>
                        <input type="email" name="email" id="email" class="form-control mb-3" required autofocus>
                        
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning">Send OTP</button>
                        </div>
                        <div class="mt-3 text-center">
                            <a href="{{ path('app_login') }}">Back to Login</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
