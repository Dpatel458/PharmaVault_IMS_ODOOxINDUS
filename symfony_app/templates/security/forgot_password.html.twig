{% extends 'base.html.twig' %}

{% block title %}Forgot Password{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="text-center mb-4">
            <i class="bi bi-key display-3 text-warning"></i>
            <h1 class="h3 mt-3 mb-1 font-weight-normal">Reset Password</h1>
            <p class="text-muted">Enter your email to receive an OTP</p>
        </div>

        <div class="card shadow border-0 p-4" style="border-radius: 1rem;">
            <div class="card-body">
                {% for message in app.flashes('danger') %}
                    <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-triangle-fill me-2"></i> {{ message }}</div>
                {% endfor %}
                
                <form method="post">
                    <div class="mb-4">
                        <label for="email" class="form-label fw-bold">Email Address</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light text-muted border-end-0"><i class="bi bi-envelope"></i></span>
                            <input type="email" name="email" id="email" class="form-control border-start-0 ps-0" placeholder="name@example.com" required autofocus>
                        </div>
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-lg btn-warning bg-gradient py-2 rounded-pill shadow-sm">
                            <i class="bi bi-send me-2"></i> Send OTP
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="mt-4 text-center">
            <p class="text-muted"><a href="{{ path('app_login') }}" class="text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i> Back to Login</a></p>
        </div>
    </div>
</div>
{% endblock %}
