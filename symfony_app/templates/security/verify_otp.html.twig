{% extends 'base.html.twig' %}

{% block title %}Verify OTP{% endblock %}

{% block body %}
<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="w-100" style="max-width: 450px;">
        <div class="text-center mb-4">
            <i class="bi bi-phone display-3 text-warning"></i>
            <h1 class="h3 mt-3 mb-1 font-weight-normal">Verification Required</h1>
            <p class="text-muted">Enter the code sent to your email</p>
        </div>

        <div class="card shadow border-0 p-4" style="border-radius: 1rem;">
            <div class="card-body">
                {% for message in app.flashes('success') %}
                    <div class="alert alert-success rounded-3"><i class="bi bi-check-circle-fill me-2"></i> {{ message }}</div>
                {% endfor %}
                {% for message in app.flashes('danger') %}
                    <div class="alert alert-danger rounded-3"><i class="bi bi-exclamation-triangle-fill me-2"></i> {{ message }}</div>
                {% endfor %}
                
                <div class="alert alert-info rounded-3 text-center mb-4">
                    <small>Code sent to <br><strong>{{ email }}</strong></small>
                </div>
                
                <form method="post">
                    <div class="mb-4 text-center">
                        <label for="otp" class="form-label fw-bold">6-Digit OTP</label>
                        <input type="text" name="otp" id="otp" class="form-control form-control-lg text-center fs-3 font-monospace letter-spacing-2 mx-auto" style="letter-spacing: 0.5rem; max-width: 200px;" maxlength="6" required autofocus autocomplete="off">
                    </div>
                    
                    <div class="d-grid mt-4">
                        <button type="submit" class="btn btn-lg btn-warning bg-gradient py-2 rounded-pill shadow-sm">
                            <i class="bi bi-shield-check me-2"></i> Verify Code
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
        <div class="mt-4 text-center">
            <p class="text-muted"><a href="{{ path('app_login') }}" class="text-decoration-none fw-bold"><i class="bi bi-arrow-left me-1"></i> Back to Login</a></p>
        </div>
    </div>
</div>
{% endblock %}
