{% extends 'base.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}
<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-4 border-bottom">
    <h1 class="h2"><i class="bi bi-shield-lock-fill text-primary me-2"></i>Admin Dashboard</h1>
    <div class="btn-toolbar mb-2 mb-md-0">
        <div class="btn-group me-2">
            <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-3">
        <div class="card text-white bg-primary h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-people display-4 mb-2"></i>
                <h5 class="card-title text-uppercase mt-2">Total Users</h5>
                <h2 class="display-5 fw-bold">{{ stats.totalUsers }}</h2>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-success h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-person-badge display-4 mb-2"></i>
                <h5 class="card-title text-uppercase mt-2">Active Admins</h5>
                <h2 class="display-5 fw-bold">{{ stats.adminCount }}</h2>
            </div>
        </div>
    </div>
    
    <div class="col-md-3">
        <div class="card text-white bg-info h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-person display-4 mb-2"></i>
                <h5 class="card-title text-uppercase mt-2">Regular Users</h5>
                <h2 class="display-5 fw-bold">{{ stats.regularUserCount }}</h2>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card text-white bg-dark h-100 shadow-sm border-0">
            <div class="card-body d-flex flex-column align-items-center justify-content-center">
                <i class="bi bi-box-seam display-4 mb-2"></i>
                <h5 class="card-title text-uppercase mt-2">Total Products</h5>
                <h2 class="display-5 fw-bold">{{ stats.totalProducts }}</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="card shadow-sm border-0 mb-4">
            <div class="card-header bg-white py-3">
                <h5 class="mb-0"><i class="bi bi-gear-fill text-secondary me-2"></i>System Overview</h5>
            </div>
            <div class="card-body">
                <p class="text-muted">Welcome to the Administration Panel. This area allows you to oversee system-wide metrics. Your role as an administrator grants you elevated permissions over normal users.</p>
                <div class="row text-center mt-4">
                    <div class="col-md-6 border-end">
                        <i class="bi bi-building fs-1 text-muted mb-2"></i>
                        <h5>Warehouses Operated</h5>
                        <h3>{{ stats.totalWarehouses }}</h3>
                    </div>
                    <div class="col-md-6">
                        <i class="bi bi-clock-history fs-1 text-muted mb-2"></i>
                        <h5>System Status</h5>
                        <h3 class="text-success">Online & Healthy</h3>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
