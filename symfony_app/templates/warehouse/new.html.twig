{% extends 'base.html.twig' %}

{% block title %}New Warehouse{% endblock %}

{% block body %}
    <div class="pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Create new Warehouse</h1>
    </div>

    <div class="card shadow-sm mb-4" style="max-width: 700px;">
        <div class="card-body">
            {{ form_start(form) }}
                <div class="row g-3">
                    <div class="col-md-8">
                        {{ form_row(form.name) }}
                    </div>
                    <div class="col-md-4">
                        {{ form_row(form.shortCode) }}
                    </div>
                    
                    <div class="col-12">
                        {{ form_row(form.location) }}
                    </div>

                    <div class="col-12">
                        {{ form_row(form.address) }}
                    </div>
                </div>
                
                <div class="mt-4">
                    <button class="btn btn-success px-4">
                        <i class="bi bi-check-lg"></i> Save Warehouse
                    </button>
                    <a href="{{ path('app_warehouse_index') }}" class="btn btn-outline-secondary ms-2">Cancel</a>
                </div>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}