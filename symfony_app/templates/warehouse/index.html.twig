{% extends 'base.html.twig' %}

{% block title %}Warehouse Index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Warehouses</h1>
        <a href="{{ path('app_warehouse_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg"></i> Create new
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-striped table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Id</th>
                        <th>Short Code</th>
                        <th>Name</th>
                        <th>Address</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for warehouse in warehouses %}
                    <tr>
                        <td>{{ warehouse.id }}</td>
                        <td><span class="badge bg-secondary">{{ warehouse.shortCode }}</span></td>
                        <td class="fw-bold">{{ warehouse.name }}</td>
                        <td>{{ warehouse.address }}</td>
                        <td class="text-center">
                            <a href="{{ path('app_warehouse_edit', {'id': warehouse.id}) }}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil"></i> edit
                            </a>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">No records found. Click "Create new" to add a warehouse.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}