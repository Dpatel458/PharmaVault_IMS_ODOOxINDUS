{% extends 'base.html.twig' %}

{% block title %}Product Index{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center pt-3 pb-2 mb-3 border-bottom">
        <h1 class="h2">Products</h1>
        <a href="{{ path('app_product_new') }}" class="btn btn-primary">Create new</a>
    </div>

    <table class="table table-striped table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>SKU</th>
                <th>Name</th>
                <th>Category</th>
                <th>Unit</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for product in products %}
            <tr>
                <td>{{ product.id }}</td>
                <td><span class="badge bg-secondary">{{ product.sku }}</span></td>
                <td>{{ product.name }}</td>
                <td>{{ product.category.name }}</td>
                <td>{{ product.unit }}</td>
                <td>
                    <a href="{{ path('app_product_edit', {'id': product.id}) }}" class="btn btn-sm btn-outline-primary">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6" class="text-center py-3">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endblock %}
