<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}IMS Dashboard{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📦</text></svg>">
        
        <!-- Bootstrap 5 CSS -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <!-- Bootstrap Icons -->
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
        
        <style>
            body {
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
                background-color: #f8f9fa;
            }
            .sidebar {
                position: fixed;
                top: 0;
                bottom: 0;
                left: 0;
                z-index: 100;
                padding: 48px 0 0;
                box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1);
                background-color: #343a40;
                color: #fff;
            }
            .sidebar .nav-link {
                color: rgba(255, 255, 255, .75);
                font-weight: 500;
                padding: 10px 20px;
            }
            .sidebar .nav-link:hover, .sidebar .nav-link.active {
                color: #fff;
                background-color: rgba(255, 255, 255, .1);
            }
            .sidebar-heading {
                font-size: .875rem;
                text-transform: uppercase;
                padding: 10px 20px;
                color: rgba(255, 255, 255, .5);
            }
            .main-content {
                margin-left: 16.66667%; /* matches col-md-3 col-lg-2 */
                padding-top: 60px;
            }
            .navbar-brand {
                padding-top: .75rem;
                padding-bottom: .75rem;
                font-size: 1.2rem;
                background-color: rgba(0, 0, 0, .25);
                box-shadow: inset -1px 0 0 rgba(0, 0, 0, .25);
            }
            
            {% block stylesheets %}{% endblock %}
        </style>
    </head>
    <body>
        <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
            <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6" href="{{ path('app_dashboard') }}">
                <i class="bi bi-box-seam me-2"></i>IMS Pro
            </a>
            
            <div class="navbar-nav">
                <div class="nav-item text-nowrap d-flex align-items-center">
                    {% if app.user %}
                        <span class="text-white me-3">Welcome, {{ app.user.name }}</span>
                        <a class="nav-link px-3 text-white bg-danger" href="{{ path('app_logout') }}">Sign out</a>
                    {% endif %}
                </div>
            </div>
        </header>

        <div class="container-fluid">
            <div class="row">
                {% if app.user %}
                <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                    <div class="position-sticky pt-3 sidebar-sticky">
                        <ul class="nav flex-column mb-auto">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_dashboard' %}active{% endif %}" aria-current="page" href="{{ path('app_dashboard') }}">
                                    <i class="bi bi-house-door me-2"></i> Dashboard
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_product_index' %}active{% endif %}" href="{{ path('app_product_index') }}">
                                    <i class="bi bi-tags me-2"></i> Products
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_category_index' %}active{% endif %}" href="{{ path('app_category_index') }}">
                                    <i class="bi bi-folder me-2"></i> Categories
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_warehouse_index' %}active{% endif %}" href="{{ path('app_warehouse_index') }}">
                                    <i class="bi bi-building me-2"></i> Warehouses
                                </a>
                            </li>
                        </ul>

                        <h6 class="sidebar-heading d-flex justify-content-between align-items-center mt-4 mb-1">
                            <span>Operations</span>
                        </h6>
                        <ul class="nav flex-column mb-auto">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_stock_' %}active{% endif %}" href="{{ path('app_stock_index') }}">
                                    <i class="bi bi-box-seam me-2"></i> Current Stock
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_receipt_' %}active{% endif %}" href="{{ path('app_receipt_index') }}">
                                    <i class="bi bi-box-arrow-in-right me-2"></i> Receipts
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_delivery_' %}active{% endif %}" href="{{ path('app_delivery_index') }}">
                                    <i class="bi bi-truck me-2"></i> Delivery Orders
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_transfer_' %}active{% endif %}" href="{{ path('app_transfer_index') }}">
                                    <i class="bi bi-arrow-left-right me-2"></i> Internal Transfers
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_adjustment_' %}active{% endif %}" href="{{ path('app_adjustment_index') }}">
                                    <i class="bi bi-sliders me-2"></i> Stock Adjustments
                                </a>
                            </li>
                        </ul>
                        
                        <h6 class="sidebar-heading d-flex justify-content-between align-items-center mt-4 mb-1">
                            <span>System</span>
                        </h6>
                        <ul class="nav flex-column mb-auto">
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="bi bi-clock-history me-2"></i> Move History
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="bi bi-gear me-2"></i> Settings
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" href="#">
                                    <i class="bi bi-person me-2"></i> Profile
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
                {% endif %}

                <main class="{% if app.user %}main-content col-md-9 ms-sm-auto col-lg-10 px-md-4{% else %}col-12 mt-4{% endif %}">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
        
        <!-- Bootstrap JS -->
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>
