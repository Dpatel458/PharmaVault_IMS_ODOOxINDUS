<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}IMS Dashboard{% endblock %}</title>
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>📦</text></svg>">
        
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css" rel="stylesheet">
        
        <style>
            body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; background-color: #f8f9fa; }
            .sidebar { position: fixed; top: 0; bottom: 0; left: 0; z-index: 100; padding: 48px 0 0; box-shadow: inset -1px 0 0 rgba(0, 0, 0, .1); background-color: #212529; color: #fff; }
            .sidebar .nav-link { color: rgba(255, 255, 255, .75); font-weight: 500; padding: 10px 20px; transition: all 0.2s; cursor: pointer; }
            .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background-color: rgba(13, 110, 253, 0.5); }
            .sidebar-heading { font-size: .75rem; text-transform: uppercase; padding: 15px 20px 5px; color: rgba(255, 255, 255, .4); letter-spacing: 1px; }
            .main-content { margin-left: 16.66667%; padding-top: 60px; }
            .navbar-brand { padding-top: .75rem; padding-bottom: .75rem; font-size: 1.2rem; background-color: rgba(0, 0, 0, .25); box-shadow: inset -1px 0 0 rgba(0, 0, 0, .25); }
            .submenu { list-style: none; padding-left: 35px; background: rgba(0,0,0,0.1); }
            
            /* Custom Modern Form Styles */
            .form-control, .form-select {
                padding: 0.75rem 1rem;
                border-radius: 0.5rem;
                border: 1px solid #ced4da;
                transition: border-color 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
            }
            .form-control:focus, .form-select:focus {
                border-color: #0d6efd;
                box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25);
            }
            .card {
                border-radius: 0.75rem;
                border: none;
                box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
            }
            .card-header {
                border-bottom: 1px solid rgba(0,0,0,.125);
                background-color: transparent;
                padding: 1.25rem 1.5rem;
            }
            .card-body { padding: 1.5rem; }
            {% block stylesheets %}{% endblock %}
        </style>
    </head>
    <body>
        <header class="navbar navbar-dark sticky-top bg-dark flex-md-nowrap p-0 shadow">
            <a class="navbar-brand col-md-3 col-lg-2 me-0 px-3 fs-6" href="{{ path('app_dashboard') }}">
                <i class="bi bi-box-seam me-2"></i>IMS Pro
            </a>
            
            {% if app.user %}
            <form class="w-100 px-3 d-none d-md-flex" style="max-width: 500px;" action="/search" method="GET">
                <div class="input-group">
                    <span class="input-group-text bg-dark text-secondary border-secondary"><i class="bi bi-search"></i></span>
                    <input type="text" name="q" class="form-control bg-dark text-white border-secondary" placeholder="Search for products, categories, warehouses..." aria-label="Search">
                </div>
            </form>
            {% else %}
            <div class="w-100"></div> {# Empty div to keep flex alignment #}
            {% endif %}
            <div class="navbar-nav">
                <div class="nav-item text-nowrap d-flex align-items-center">
                    {% if app.user %}
                        <a class="nav-link px-3 text-white" href="{{ path('app_profile') }}">
                            <i class="bi bi-person-circle me-1"></i> {{ app.user.name }}
                        </a>
                        <a class="nav-link px-3 text-white bg-danger" href="{{ path('app_logout') }}">Sign out</a>
                    {% endif %}
                </div>
            </div>
        </header>

        <div class="container-fluid">
            <div class="row">
                {% if app.user %}
                <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse">
                    <div class="position-sticky pt-3 sidebar-sticky">
                        
                        <h6 class="sidebar-heading">Dashboard</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_dashboard' %}active{% endif %}" href="{{ path('app_dashboard') }}">
                                    <i class="bi bi-speedometer2 me-2"></i> Dashboard
                                </a>
                            </li>
                        </ul>

                        <h6 class="sidebar-heading mt-4 mb-1">Operations</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_stock_index' %}active{% endif %}" href="{{ path('app_stock_index') }}">
                                    <i class="bi bi-box-seam me-2"></i> Stock
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_move_history' %}active{% endif %}" href="{{ path('app_move_history') }}">
                                    <i class="bi bi-clock-history me-2"></i> Move History
                                </a>
                            </li>
                        </ul>

                        <h6 class="sidebar-heading mt-4 mb-1">Master Data</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_product' %}active{% endif %}" href="{{ path('app_product_index') }}">
                                    <i class="bi bi-tags me-2"></i> Products
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') starts with 'app_category' %}active{% endif %}" href="{{ path('app_category_index') }}">
                                    <i class="bi bi-folder me-2"></i> Categories
                                </a>
                            </li>
                        </ul>

                        <h6 class="sidebar-heading mt-4 mb-1">Configuration</h6>
                        <ul class="nav flex-column">
                            <li class="nav-item">
                                <a class="nav-link d-flex justify-content-between align-items-center" data-bs-toggle="collapse" data-bs-target="#settingsSubmenu" aria-expanded="false">
                                    <span><i class="bi bi-gear me-2"></i> Settings</span>
                                    <i class="bi bi-chevron-down small"></i>
                                </a>
                                <div class="collapse {% if app.request.attributes.get('_route') starts with 'app_warehouse' or app.request.attributes.get('_route') starts with 'app_location' %}show{% endif %}" id="settingsSubmenu">
                                    <ul class="submenu nav flex-column">
                                        <li class="nav-item">
                                            <a class="nav-link py-1 {% if app.request.attributes.get('_route') starts with 'app_warehouse' %}active text-white{% endif %}" href="{{ path('app_warehouse_index') }}">
                                                <i class="bi bi-building me-2"></i> Warehouses
                                            </a>
                                        </li>
                                        <li class="nav-item">
                                            {# HAVE AA LINK SACHI CHE #}
                                            <a class="nav-link py-1 {% if app.request.attributes.get('_route') starts with 'app_location' %}active text-white{% endif %}" href="{{ path('app_location_index') }}">
                                                <i class="bi bi-geo-alt me-2"></i> Locations
                                            </a>
                                        </li>
                                    </ul>
                                </div>
                            </li>
                        </ul>
                    </div>
                </nav>
                {% endif %}

                {% if is_granted('ROLE_ADMIN') %}
                <nav id="sidebarAdminMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse" style="top: auto; bottom: 0; padding-top: 0; height: auto;">
                    <div class="position-sticky pt-3 pb-3 sidebar-sticky border-top border-secondary">
                        <ul class="nav flex-column mb-0">
                            <li class="nav-item">
                                <a class="nav-link {% if app.request.attributes.get('_route') == 'app_admin_dashboard' %}active{% endif %} text-warning" href="{{ path('app_admin_dashboard') }}">
                                    <i class="bi bi-shield-lock-fill me-2"></i> Admin Panel
                                </a>
                            </li>
                        </ul>
                    </div>
                </nav>
                {% endif %}

                <main class="{% if app.user %}main-content col-md-9 ms-sm-auto col-lg-10 px-md-4{% else %}col-12 mt-4{% endif %}">
                    {% block body %}{% endblock %}
                </main>
            </div>
        </div>
        
        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
        {% block javascripts %}{% endblock %}
    </body>
</html>